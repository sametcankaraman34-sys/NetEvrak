# Postgres bağlantı örneği (değerleri kendi ortamına göre güncelle)
DATABASE_URL=postgresql://user:password@localhost:5432/vertical_doc_control?schema=public

# Storage (lokal dev için)
STORAGE_PROVIDER=local
UPLOAD_DIR=uploads

# Queue
QUEUE_PROVIDER=in_memory
REDIS_URL=redis://localhost:6379

# Auth / App
NEXTAUTH_SECRET=change_me
NEXTAUTH_URL=http://localhost:3000

# Monitoring
ERROR_MONITOR_PROVIDER=console
SENTRY_DSN=


